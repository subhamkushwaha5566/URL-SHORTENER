<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>URL Shortener Dashboard</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f8f9fa;
      }
      .header {
        background-color: #198754; /* Bootstrap green */
        color: white;
        padding: 20px;
        border-radius: 8px;
      }
      .form-section {
        background-color: white;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
      }
      .table-section {
        margin-top: 30px;
      }
    </style>
  </head>
  <body>
    <div class="container mt-4">
      <div class="header text-center">
        <h1>🌿 URL Shortener</h1>
        <% if (locals.id) { %>
          <p class="mt-2">✅ URL Generated: <a href="/url/<%= id %>" class="text-warning">http://localhost:8001/url/<%= id %></a></p>
        <% } %>
      </div>

      <div class="form-section mt-4">
        <form method="POST" action="/url">
          <div class="mb-3">
            <label class="form-label">Enter Your Original URL</label>
            <input type="text" name="url" class="form-control" placeholder="https://example.com" required />
          </div>
          <button type="submit" class="btn btn-success w-100">Generate Short URL</button>
        </form>
      </div>

      <% if (locals.urls && urls.length > 0) { %>
        <div class="table-section">
          <h3 class="mt-5">📊 Your URLs</h3>
          <table class="table table-striped table-bordered mt-3">
            <thead class="table-success">
              <tr>
                <th>#</th>
                <th>Short ID</th>
                <th>Redirect URL</th>
                <th>Clicks</th>
              </tr>
            </thead>
            <tbody>
              <% urls.forEach((url, index) => { %>
                <tr>
                  <td><%= index + 1 %></td>
                  <td><a href="/url/<%= url.shortId %>" class="text-success fw-bold"><%= url.shortId %></a></td>
                  <td><%= url.redirectURL %></td>
                  <td><span class="badge bg-success"><%= url.visitHistory.length %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-muted mt-5">You haven’t created any URLs yet.</p>
      <% } %>
    </div>
  </body>
</html>